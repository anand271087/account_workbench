# Backend environment — server-only secrets.
# NEVER expose anything here in frontend code or commit to git.

# ============================================================
# Server config
# ============================================================
API_PORT=8000
API_HOST=0.0.0.0
LOG_LEVEL=INFO
ENV=development                          # development | staging | production

# Allowed origins for CORS — comma-separated
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================
# Supabase — server-side
# ============================================================
SUPABASE_URL=https://your-project-ref.supabase.co

# ⚠️ SERVICE ROLE — bypasses RLS. NEVER expose to browser. NEVER commit.
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT secret — used to verify incoming user JWTs without a DB hop
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard

# Direct Postgres connection — used by Alembic for migrations
# Format: postgresql+asyncpg://postgres:<password>@db.<ref>.supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# ============================================================
# Anthropic — Claude AI
# ============================================================
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-5

# ============================================================
# Redis — Celery broker + AI cache
# ============================================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================================================
# Observability (optional in dev, required in prod)
# ============================================================
# SENTRY_DSN=

# ============================================================
# Rate limits (per IP per minute)
# ============================================================
RATE_LIMIT_AUTH=100
RATE_LIMIT_DEFAULT=1000

# ============================================================
# File upload constraints
# ============================================================
MAX_UPLOAD_SIZE_MB=100
ALLOWED_DOC_EXTENSIONS=.docx,.doc,.pptx,.ppt,.xlsx,.xls,.pdf,.txt,.vtt,.eml
