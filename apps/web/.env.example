# Frontend environment — Vite picks up only VITE_* prefixed vars.
# Anything here is bundled into the JS shipped to the browser.
# Only put PUBLIC values here. Never service-role keys, never API keys.

# Supabase — public anon key is RLS-protected, safe to ship to browser
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Backend API base URL
# Local dev: http://localhost:8000
# Vercel preview: https://api-staging.beroe-awb.com
# Production: https://api.beroe-awb.com
VITE_API_BASE_URL=http://localhost:8000

# Sentry (optional — set in production only)
# VITE_SENTRY_DSN=

# Build metadata (auto-injected in CI; safe defaults locally)
VITE_BUILD_VERSION=local
VITE_BUILD_COMMIT=dev
