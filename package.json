{
  "name": "beroe-awb",
  "version": "0.1.0",
  "private": true,
  "description": "Beroe Account Workbench (AWB) - monorepo",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yml,yaml}\"",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "secrets:scan": "gitleaks detect --source . --verbose"
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
