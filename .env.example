# Root-level environment — Supabase MCP only.
# Copy to `.env` (which is gitignored) and fill in real values.
# DO NOT commit .env.

# ============================================================
# Supabase MCP — lets Claude Code manage Supabase schema/RLS/seed
# ============================================================

# Personal Access Token from https://supabase.com/dashboard/account/tokens
# Generate with read+write scope. NEVER commit this.
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase project ref (e.g. "abcdefghijklmnop") — found in dashboard URL
SUPABASE_PROJECT_REF=your-project-ref

# Optional: read-only mode for MCP (recommended for production projects)
# Set to "true" if you don't want Claude to apply DDL via MCP.
SUPABASE_READ_ONLY=false
